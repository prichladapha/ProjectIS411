### สร้าง region กรุงเทพมหานคร ปทุมธานี กาญจนบุรี
POST http://127.0.0.1:8000/regions

{
    "name_th": "กรุงเทพมหานคร",
    "total_population": 10500000
  }

###
POST http://127.0.0.1:8000/regions

{
    "name_th": "กาญจนบุรี",
    "total_population": 890000
  }

###
GET http://127.0.0.1:8000/regions

### สร้าง constituencies 
### กทม เขต 1
POST http://127.0.0.1:8000/constituencies

{
  "region_id": 1,
  "const_number": 1,
  "total_eligible_voters": 50000
}

### กทม เขต 2
POST http://127.0.0.1:8000/constituencies

{
  "region_id": 1,
  "const_number": 2,
  "total_eligible_voters": 57000
}

### กาญ เขต 1
POST http://127.0.0.1:8000/constituencies

{
  "region_id": 2,
  "const_number": 1,
  "total_eligible_voters": 36000
}

### 1) เพิ่ม/แสดง พรรคการเมือง และผู้สมัคร ส.ส. เขต
### (อย่างน้อย 2 เขต เขตละ 3 พรรค/ผู้สมัคร)
# เพิ่มพรรคการเมือง
POST http://127.0.0.1:8000/parties

{
  "party_name": "เพื่อพี่แจมิน",
  "party_leader": "น้ำผัก รักพี่",
  "party_logo_url": "https://example.com/ptp.png"
}

###
POST http://127.0.0.1:8000/parties

{
  "party_name": "พัฒนาเพื่อน้องอินจุน",
  "party_leader": "ลี เจน",
  "party_logo_url": "https://example.com/ptp.png"
}

###
POST http://127.0.0.1:8000/parties

{
  "party_name": "อยากเห็นคนไทยเป็นสาววาย",
  "party_leader": "สาววาย ชิปโน่เหรินมิน",
  "party_logo_url": "https://example.com/ptp.png"
}

### แสดงรายชื่อพรรคการเมืองทั้งหมด
GET http://127.0.0.1:8000/parties

### แสดงข้อมูลพรรคการเมืองตาม id
GET http://127.0.0.1:8000/parties/1

### เพิ่มผู้สมัคร ส.ส.เขต 1 กทม พรรคเพื่อพี่แจมิน 
POST http://127.0.0.1:8000/candidates

{
  "const_id": 1,
  "party_id": 1,
  "candidate_number": 1,
  "full_name": "นายสมชาย ใจดี"
}

### เพิ่มผู้สมัคร ส.ส.เขต 1 กทม พรรคพัฒนาเพื่อน้องอินจุน
POST http://127.0.0.1:8000/candidates

{
  "const_id": 1,
  "party_id": 2,
  "candidate_number": 2,
  "full_name": "นางสาวสุดา มีสุข"
}

### เพิ่มผู้สมัคร ส.ส.เขต 1 กทม พรรคอยากเห็นคนไทยเป็นสาววาย
POST http://127.0.0.1:8000/candidates

{
  "const_id": 1,
  "party_id": 3,
  "candidate_number": 3,
  "full_name": "นายประยงค์ รักชาติ"
}

### เพิ่มผู้สมัคร ส.ส.เขต 2 กทม พรรคเพื่อพี่แจมิน 
POST http://127.0.0.1:8000/candidates

{
  "const_id": 2,
  "party_id": 1,
  "candidate_number": 1,
  "full_name": "นางวิไล สว่างใจ"
}

### เพิ่มผู้สมัคร ส.ส.เขต 2 กทม พรรคพัฒนาเพื่อน้องอินจุน
POST http://127.0.0.1:8000/candidates

{
  "const_id": 2,
  "party_id": 2,
  "candidate_number": 2,
  "full_name": "นายธนกฤต พัฒนา"
}

### เพิ่มผู้สมัคร ส.ส.เขต 2 กทม พรรคอยากเห็นคนไทยเป็นสาววาย
POST http://127.0.0.1:8000/candidates

{
  "const_id": 2,
  "party_id": 3,
  "candidate_number": 3,
  "full_name": "นายชาติชาย อนุไทย"
}

### แสดงผู้สมัครทั้งหมด
GET http://127.0.0.1:8000/candidates

### แสดงผู้สมัคร เขต 1 
GET http://127.0.0.1:8000/candidates?const_id=1

### แสดงผู้สมัคร เขต 2
GET http://127.0.0.1:8000/candidates?const_id=2

